# Cloud Run + GitHub Actions secrets (do not commit filled copy)

GCP_PROJECT_ID=your-gcp-project
GCP_REGION=asia-south1
CLOUD_RUN_SERVICE=mrmed-agent

# Public HTTPS URL of this service (no trailing slash) — required for Exotel wss
AGENT_PUBLIC_URL=https://mrmedagent-432303484897.asia-south1.run.app

# Gemini Live
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_VOICE_NAME=Aoede
LLM_TEMPERATURE=0.1

# Embedded Cube (localhost:4000 inside the container — no external Cube service)
CUBEJS_API_SECRET=change_me_to_a_long_random_secret
CUBEJS_DEV_MODE=false
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=your-railway-host
CUBEJS_DB_PORT=25478
CUBEJS_DB_NAME=railway
CUBEJS_DB_USER=postgres
CUBEJS_DB_PASS=your_db_password
CUBEJS_DB_SSL=true
CUBEJS_DB_SSL_REJECT_UNAUTHORIZED=false

# Railway Postgres (public URL for Cloud Run)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require

# Post-call CRM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
POSTPROCESS_MAX_CONCURRENT=5

# Exotel
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_APP_ID=
EXOTEL_PHONE_NUMBER=
EXOTEL_CONNECT_API_BASE_URL=https://api.exotel.com

# Dial-out helper (optional; point at this Cloud Run URL)
AGENT_SERVER_URL=https://mrmedagent-432303484897.asia-south1.run.app
