# Copy to .github/workflows/deploy-agent.yml in your agent repo.
# Build context MUST be the folder that contains both agent/ and DB/scripts/
# (e.g. push AICaller/ subtree or whole monorepo with paths below).

name: Deploy agent to Cloud Run

on:
  push:
    branches: [main]
    paths:
      - 'agent/**'
      - 'DB/scripts/cube_tools.py'
  workflow_dispatch:

env:
  PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
  REGION: ${{ secrets.GCP_REGION }}
  SERVICE: mrmed-agent

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ secrets.GCP_SA_KEY }}

      - uses: google-github-actions/setup-gcloud@v2

      - run: gcloud auth configure-docker --quiet

      - run: |
          docker build -f agent/Dockerfile -t gcr.io/$PROJECT_ID/$SERVICE:${{ github.sha }} .
          docker push gcr.io/$PROJECT_ID/$SERVICE:${{ github.sha }}

      - run: |
          gcloud run deploy $SERVICE \
            --image gcr.io/$PROJECT_ID/$SERVICE:${{ github.sha }} \
            --region $REGION \
            --platform managed \
            --allow-unauthenticated \
            --port 8080 \
            --memory 2Gi \
            --cpu 1 \
            --timeout 3600 \
            --min-instances 1 \
            --set-env-vars "\
          AGENT_PUBLIC_URL=${{ secrets.AGENT_PUBLIC_URL }},\
          GEMINI_API_KEY=${{ secrets.GEMINI_API_KEY }},\
          GEMINI_MODEL=${{ secrets.GEMINI_MODEL }},\
          GEMINI_VOICE_NAME=${{ secrets.GEMINI_VOICE_NAME }},\
          LLM_TEMPERATURE=0.1,\
          CUBE_BASE=${{ secrets.CUBE_BASE }},\
          CUBEJS_API_SECRET=${{ secrets.CUBEJS_API_SECRET }},\
          DATABASE_URL=${{ secrets.DATABASE_URL }},\
          GROQ_API_KEY=${{ secrets.GROQ_API_KEY }},\
          GROQ_MODEL=${{ secrets.GROQ_MODEL }},\
          EXOTEL_API_KEY=${{ secrets.EXOTEL_API_KEY }},\
          EXOTEL_API_TOKEN=${{ secrets.EXOTEL_API_TOKEN }},\
          EXOTEL_SID=${{ secrets.EXOTEL_SID }},\
          EXOTEL_APP_ID=${{ secrets.EXOTEL_APP_ID }},\
          EXOTEL_PHONE_NUMBER=${{ secrets.EXOTEL_PHONE_NUMBER }},\
          EXOTEL_CONNECT_API_BASE_URL=https://api.exotel.com"
