# Vertex AI Live (voice) — required for server.py
# Inline JSON or path to service-account .json file
VERTEX_CREDENTIALS=
GOOGLE_VERTEX_CREDENTIALS=
GOOGLE_CLOUD_PROJECT_ID=
# Vertex Live region (default europe-west4 — do not reuse GOOGLE_CLOUD_LOCATION)
VERTEX_LOCATION=europe-west4
VERTEX_MODEL=google/gemini-live-2.5-flash-native-audio
VERTEX_VOICE=Autonoe
LLM_TEMPERATURE=0.2

# Embedded Cube (always localhost:4000 — started automatically with the agent)
CUBEJS_API_SECRET=change_me_to_a_long_random_secret
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=localhost
CUBEJS_DB_PORT=5433
CUBEJS_DB_NAME=meddb
CUBEJS_DB_USER=meduser
CUBEJS_DB_PASS=medpass
# CUBEJS_DB_SSL=true
CUBEJS_DEV_MODE=true
# Speed: in-memory cache TTL (seconds), HTTP timeout, skip bulk fetch on alternatives (0=fast)
CUBE_CACHE_TTL_SECS=300
CUBE_HTTP_TIMEOUT=30
CUBE_ATTACH_BULK_ON_ALTERNATIVES=0

DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
POSTPROCESS_MAX_CONCURRENT=5

# Daily.co — browser voice sessions (required)
DAILY_API_KEY=

# Local dev: auto-start ngrok and set AGENT_PUBLIC_URL for this agent process
# Set USE_NGROK=0 to skip ngrok and use AGENT_PUBLIC_URL or localhost instead
NGROK_AUTH_TOKEN=
USE_NGROK=1

# This agent service's public URL (Cloud Run URL when deployed; ngrok URL when local)
AGENT_PUBLIC_URL=

# Legacy Exotel telephony (optional — not used for Daily UI)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_APP_ID=
EXOTEL_PHONE_NUMBER=
EXOTEL_CONNECT_API_BASE_URL=https://api.exotel.com

# Cloud Run public URL (optional)
AGENT_PUBLIC_URL=https://your-agent.run.app
